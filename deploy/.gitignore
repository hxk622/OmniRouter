# =============================================================================
# OmniRouter Deploy Directory - Git Ignore
# =============================================================================

# Data directories (generated at runtime when using docker-compose.local.yml)
data/
postgres_data/
redis_data/

# Environment configuration (contains sensitive information)
.env

# Backup files
*.backup
*.bak
*.backup-*/
data.backup-*/
postgres_data.backup-*/
redis_data.backup-*/

# Temporary files
*.tmp
*.log
